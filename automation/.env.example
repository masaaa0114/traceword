# ============================================
# TraceWords 自動化システム — 環境変数
# このファイルを .env にリネームして値を入力
# .gitignore に .env を必ず追加すること
# ============================================

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Notion API
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx

# Notion データベース ID（Notion URL から取得）
NOTION_DAILY_LOG_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_WEEKLY_REPORT_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TASK_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DECISION_LOG_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_KPI_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub（コードレビュー用）
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=your-username/tracewords

# 通知メール（オプション）
NOTIFY_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# タイムゾーン
TIMEZONE=Asia/Tokyo
